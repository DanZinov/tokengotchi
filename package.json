{
  "name": "tokengotchi",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "An idle auto-battler fueled by your real AI coding token usage. Your work powers your hero.",
  "keywords": [
    "idle-game",
    "rpg",
    "cli",
    "ai",
    "claude-code",
    "codex",
    "tokens",
    "pixijs",
    "ccusage"
  ],
  "homepage": "https://danzinov.github.io/tokengotchi/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanZinov/tokengotchi.git"
  },
  "bugs": {
    "url": "https://github.com/DanZinov/tokengotchi/issues"
  },
  "author": "Daniil Zinovyev",
  "license": "MIT",
  "bin": {
    "tokengotchi": "./bin/tokengotchi.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:engine": "tsx watch src/cli/main.ts --mock --no-open",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:cli",
    "build:client": "vite build",
    "build:cli": "esbuild src/cli/main.ts --bundle --platform=node --format=esm --packages=external --outfile=bin/tokengotchi.mjs --banner:js=\"#!/usr/bin/env node\" && chmod +x bin/tokengotchi.mjs",
    "start": "tsx src/cli/main.ts",
    "start:mock": "tsx src/cli/main.ts --mock",
    "demo": "npm run build:client && tsx src/cli/main.ts --mock --interval=4000",
    "sync:once": "tsx src/cli/main.ts --once",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.2",
    "gsap": "^3.12.5",
    "pixi.js": "^8.6.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
